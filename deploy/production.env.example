#
# MODEL050426 production-like env template
#
# Copy this file to repo-root `.env` before local or VPS runs.
# Use Bybit demo credentials here, not production keys.
#
# The sections below are grouped by operational impact:
# - Exchange / execution / risk: affects whether the bot can trade and how hard
# - Telegram: affects what noise you get in chat
# - High-impact signal quality: the first knobs to revisit if signal quality looks bad
# - Intrabar behavior: affects how early and how often entries can happen
# - Runtime / persistence: affects liveness, logging, and analysis
#

#
# Exchange / venue
#
BYBIT_REST_BASE_URL=https://api.bybit.com
BYBIT_WS_BASE_URL=wss://stream.bybit.com/v5/public/linear
BYBIT_TRADE_BASE_URL=https://api-demo.bybit.com
BYBIT_CATEGORY=linear
BYBIT_API_KEY=REPLACE_WITH_DEMO_KEY
BYBIT_API_SECRET=REPLACE_WITH_DEMO_SECRET
BYBIT_RECV_WINDOW=5000
TRADE_FILL_POLL_ATTEMPTS=10
TRADE_FILL_POLL_DELAY_SECONDS=0.5

#
# Execution / risk
#
# With EXECUTION_SUBMIT_ORDERS=true the bot sends real market orders to the
# Bybit demo account on api-demo.bybit.com, then sets venue-managed TP/SL.
# The current execution path is momentum-long: it buys to open and sells to exit.
# Set EXECUTION_SUBMIT_ORDERS=false if you only want local simulated fills.
EXECUTION_ENABLED=true
DEMO_MODE=true
EXECUTION_SUBMIT_ORDERS=true

# Simulated-only fixed notional. Live venue sizing uses RISK_PER_TRADE_PCT.
ENTRY_NOTIONAL_USD=100

# Risk budget per trade as a fraction of available balance.
# Example: 0.01 means "lose about 1% of available balance if SL is hit".
RISK_PER_TRADE_PCT=0.01

# Portfolio-wide safety cap across already-open plus freshly-opened positions.
# 0 means unlimited.
MAX_OPEN_POSITIONS=3

# Correlation safety cap by cluster. 0 means unlimited.
# Clusters are always based on recent correlation now.
MAX_POSITIONS_PER_CLUSTER=1

# Long-side exits:
# TAKE_PROFIT_PCT=0.02 means target a 2% move up from entry.
# STOP_LOSS_PCT=0.02 means stop 2% below entry.
# STALE_POSITION_MAX_MINUTES=240 means close the trade after 4 hours if neither
# level has been hit. Set 0 to disable the deadline entirely.
# BREAK_EVEN_STOP_ENABLED=true arms a one-step stop-to-entry ratchet instead of
# a true trailing stop. The trigger is TAKE_PROFIT_PCT multiplied by
# BREAK_EVEN_STOP_TRIGGER_FRACTION_OF_TP, so 0.75 means "arm at 75% of the way
# to the current TP target".
# PROFIT_RATCHET_ENABLED=true keeps the position open when TP is reached,
# provided the ticker still satisfies the configured hold rule. The engine then
# extends TP by one base-TP rung and lifts SL one rung behind. This is
# engine-managed on purpose; venue TP must stay disabled in this mode or Bybit
# will close the trade before the ratchet logic can act.
TAKE_PROFIT_PCT=0.02
STOP_LOSS_PCT=0.02
STALE_POSITION_MAX_MINUTES=240
BREAK_EVEN_STOP_ENABLED=false
BREAK_EVEN_STOP_TRIGGER_FRACTION_OF_TP=0.75
PROFIT_RATCHET_ENABLED=false
PROFIT_RATCHET_MAX_STEPS=0

# UTC-day kill switch. 0 means disabled.
MAX_DAILY_STOP_LOSSES=0

# Hard operator brake. When true, the bot still ranks and logs, but fresh
# entries are skipped with an explicit control event.
OPERATOR_PAUSE_NEW_ENTRIES=false

#
# Telegram
#
# Rotate your Telegram token before using this file.
TELEGRAM_BOT_TOKEN=REPLACE_WITH_ROTATED_TOKEN
TELEGRAM_CHAT_ID=REPLACE_WITH_CHAT_ID

# Master switch for signal-candidate Telegram alerts (`watchlist`, `emerging`,
# `entry_ready`).
# Set this to false if you only want execution entry/exit messages.
TELEGRAM_SIGNAL_ALERTS_ENABLED=true

#
# High-impact signal quality
#
# If the bot feels noisy or low-quality, start here before touching infrastructure.
HURST_WINDOW=96
HURST_CUTOFF=0.40
BTC_REALIZED_VOL_THRESHOLD=0.65

# Intraday tradeability gate. This is the practical no-trade filter for chop /
# anti-momentum sessions. It blocks `entry_ready` promotion when too few of the
# checks pass: breadth, basket drift, trend efficiency, and recent leader persistence.
INTRADAY_REGIME_FILTER_ENABLED=true
INTRADAY_REGIME_LOOKBACK_BARS=16
INTRADAY_REGIME_TOP_N=3
INTRADAY_REGIME_MIN_BREADTH=0.55
INTRADAY_REGIME_MIN_EFFICIENCY=0.35
INTRADAY_REGIME_MIN_BASKET_RETURN=0.00
INTRADAY_REGIME_MIN_LEADERSHIP_PERSISTENCE=0.25
INTRADAY_REGIME_MIN_PASS_COUNT=3

MOMENTUM_LOOKBACK=48
MOMENTUM_SKIP=4
# Residual momentum mode:
# - absolute
# - btc_relative
# - basket_relative
# - cluster_relative
MOMENTUM_REFERENCE_MODE=cluster_relative

# Correlation clustering drives both cluster-relative momentum and the cluster
# exposure cap.
CLUSTER_CORRELATION_LOOKBACK_BARS=48
CLUSTER_CORRELATION_THRESHOLD=0.7

MOMENTUM_WEIGHT=0.85
MOMENTUM_Z_CLIP=3.0

CURVATURE_MA_WINDOW=8
CURVATURE_SIGNAL_WINDOW=6
CURVATURE_WEIGHT=0.15
CURVATURE_Z_CLIP=2.5

MIN_VOLATILITY=0.00001
TOP_N=3

#
# Intrabar ranking behavior
#
CANDLE_INTERVAL=15
STATE_WINDOW=288
RANKING_LOG_TOP_N=5

WATCHLIST_TOP_N=8
EMERGING_TOP_N=5
EMERGING_MIN_OBSERVATIONS=3
EMERGING_MIN_RANK_IMPROVEMENT=2
EMERGING_COOLDOWN_MINUTES=15
WATCHLIST_COOLDOWN_MINUTES=15

# `entry_ready` is the only tradeable signal tier. Keep this stricter than
# broad `emerging` context so the live path stays simple.
ENTRY_READY_TOP_N=4
ENTRY_READY_COOLDOWN_MINUTES=15
ENTRY_READY_MIN_OBSERVATIONS=4
ENTRY_READY_MIN_RANK_IMPROVEMENT=2
ENTRY_READY_MIN_COMPOSITE_GAIN=0.02

#
# Macro / BTC / BTCDOM inputs
#
BTC_DAILY_LOOKBACK=220
BTC_VOL_LOOKBACK=30
BINANCE_FUTURES_BASE_URL=https://fapi.binance.com
BTCDOM_SYMBOL=BTCDOMUSDT
BTCDOM_INTERVAL=1h
BTCDOM_HISTORY_LOOKBACK=96
BTCDOM_EMA_PERIOD=5
BTCDOM_STATE_LOOKBACK_BARS=4
BTCDOM_NEUTRAL_THRESHOLD_PCT=0.002

#
# Runtime / connectivity
#
BOOTSTRAP_CONCURRENCY=8
RATE_LIMIT_RETRIES=6
RATE_LIMIT_BACKOFF_SECONDS=2
WEBSOCKET_PING_SECONDS=20
RECONNECT_BASE_DELAY=1
RECONNECT_MAX_DELAY=30
CYCLE_SETTLE_SECONDS=2
EMERGING_SETTLE_SECONDS=0.5
EMERGING_INTERVAL_SECONDS=10
MACRO_REFRESH_SECONDS=3600
QUEUE_MAXSIZE=4096

#
# Persistence / analytics
#
SQLITE_PATH=/opt/MODEL05042026/data/signals.sqlite3
LOG_LEVEL=INFO
ANALYTICS_ENABLED=true
ANALYTICS_LOG_POSITION_MARKS=true
ANALYTICS_LOG_PORTFOLIO_SNAPSHOTS=true
ANALYTICS_PORTFOLIO_SNAPSHOT_ON_EMERGING=false
ANALYTICS_POST_EXIT_BARS=24

# Runtime control-plane logging. These create run manifests, health snapshots,
# and drift / control events in SQLite so `monitor.py` and later analysis can
# inspect what the service was actually doing.
RUNTIME_HEALTH_SNAPSHOT_ENABLED=true
RUNTIME_HEALTH_SNAPSHOT_SECONDS=60
RUNTIME_DRIFT_CHECK_ENABLED=true
RUNTIME_DRIFT_CHECK_SECONDS=120

#
# Backtest / research
#
# These only affect `backtest.py`, not the live runtime.
BACKTEST_STARTING_EQUITY_USD=100000
BACKTEST_FEE_RATE=0.00055
BACKTEST_SLIPPAGE_BPS=2
BACKTEST_MAX_GROSS_EXPOSURE_MULTIPLE=1.5
BACKTEST_INTRABAR_INTERVAL=1
BACKTEST_CACHE_ENABLED=true
BACKTEST_CACHE_PATH=/opt/MODEL05042026/data/backtest-candles.sqlite3
BACKTEST_RESEARCH_FAST=false
BACKTEST_VARIANT_WORKERS=1
BACKTEST_UNIVERSE_POLICY=window_available
BACKTEST_MIN_ACTIVE_UNIVERSE=1

#
# Optional universe override
#
# Uncomment if you want to override the manual universe.
# UNIVERSE=INJUSDT,STXUSDT,RENDERUSDT
