#
# Exchange
#
# Copy these values into a repo-root `.env` file before local or VPS runs.
# Use Bybit demo credentials here, not production keys.
BYBIT_REST_BASE_URL=https://api.bybit.com
BYBIT_WS_BASE_URL=wss://stream.bybit.com/v5/public/linear
BYBIT_TRADE_BASE_URL=https://api-demo.bybit.com
BYBIT_CATEGORY=linear
BYBIT_API_KEY=REPLACE_WITH_DEMO_KEY
BYBIT_API_SECRET=REPLACE_WITH_DEMO_SECRET

#
# Candle / history windows
#
CANDLE_INTERVAL=15
CANDLE_INTERVAL_MINUTES=15
STATE_WINDOW=288
BTC_DAILY_LOOKBACK=220
BTC_VOL_LOOKBACK=30
BINANCE_FUTURES_BASE_URL=https://fapi.binance.com
BTCDOM_SYMBOL=BTCDOMUSDT
BTCDOM_INTERVAL=1h
BTCDOM_HISTORY_LOOKBACK=96
BTCDOM_EMA_PERIOD=5
BTCDOM_STATE_LOOKBACK_BARS=4
BTCDOM_NEUTRAL_THRESHOLD_PCT=0.002
MOMENTUM_LOOKBACK=48
MOMENTUM_SKIP=4
CURVATURE_MA_WINDOW=8
CURVATURE_SIGNAL_WINDOW=6
HURST_WINDOW=96
HURST_CUTOFF=0.40

#
# Cross-sectional ranking / signal thresholds
#
MIN_VOLATILITY=0.00001
TOP_N=3
WATCHLIST_TOP_N=8
EMERGING_TOP_N=5
CONFIRMED_PERSISTENCE_WINDOW=3
CONFIRMED_PERSISTENCE_MIN_HITS=2
CONFIRMED_PERSISTENCE_RANK=3
RANKING_LOG_TOP_N=5
TELEGRAM_SUMMARY_ENABLED=true
SUMMARY_TOP_N=5
SUMMARY_BOTTOM_N=5
COOLDOWN_HOURS=12
WATCHLIST_COOLDOWN_MINUTES=15
EMERGING_COOLDOWN_MINUTES=15
EMERGING_MIN_OBSERVATIONS=3
EMERGING_MIN_RANK_IMPROVEMENT=2
BTC_REALIZED_VOL_THRESHOLD=0.65
MOMENTUM_WEIGHT=0.85
CURVATURE_WEIGHT=0.15
MOMENTUM_Z_CLIP=3.0
CURVATURE_Z_CLIP=2.5
CONFIRMED_STABILITY_WEIGHT=0.25
WATCHLIST_TELEGRAM_ENABLED=false

#
# Entry-ready middle tier
#
# `entry_ready` is the trader-facing midpoint between `emerging` and
# `confirmed`. It is still driven by the intrabar lifecycle, but it now has
# explicit knobs so the midpoint can be tighter than broad emerging context
# without waiting for the close.
ENTRY_READY_TOP_N=4
ENTRY_READY_COOLDOWN_MINUTES=15
ENTRY_READY_MIN_OBSERVATIONS=4
ENTRY_READY_MIN_RANK_IMPROVEMENT=2
ENTRY_READY_MIN_COMPOSITE_GAIN=0.02

#
# Execution scaffold
#
# With EXECUTION_SUBMIT_ORDERS=true the bot sends real market orders to the
# Bybit demo account on api-demo.bybit.com, then sets exchange-native TP/SL.
# The current execution path is short-only: it sells to open and buys to cover.
# Set this back to false if you want local simulated fills instead.
EXECUTION_ENABLED=true
DEMO_MODE=true
EXECUTION_SUBMIT_ORDERS=true
ENTRY_NOTIONAL_USD=100
RISK_PER_TRADE_PCT=0.01
# Portfolio-wide safety cap across already-open plus freshly-opened positions.
# 0 means unlimited.
MAX_OPEN_POSITIONS=3
# Limit how many fresh entries one emerging rebalance cycle can open.
# 0 means unlimited.
MAX_ENTRIES_PER_REBALANCE=0
TAKE_PROFIT_PCT=0.03
STOP_LOSS_PCT=0.02
MAX_DAILY_STOP_LOSSES=0
EXIT_ON_LOST_CONFIRMED=false
BYBIT_RECV_WINDOW=5000
TRADE_FILL_POLL_ATTEMPTS=10
TRADE_FILL_POLL_DELAY_SECONDS=0.5

#
# BTCDOM macro input
#
# BTCDOM is fetched from Binance futures history and normalized to a tri-state
# dominance signal:
#   falling / neutral / rising
# The configured symbol may use a TradingView-style suffix, but the client
# strips ".P" and hits the public Binance futures klines endpoint.

#
# Runtime / connectivity
#
BOOTSTRAP_CONCURRENCY=8
RATE_LIMIT_RETRIES=6
RATE_LIMIT_BACKOFF_SECONDS=2
WEBSOCKET_PING_SECONDS=20
RECONNECT_BASE_DELAY=1
RECONNECT_MAX_DELAY=30
CYCLE_SETTLE_SECONDS=2
EMERGING_SETTLE_SECONDS=0.5
EMERGING_INTERVAL_SECONDS=10
MACRO_REFRESH_SECONDS=3600
QUEUE_MAXSIZE=4096

#
# Persistence / logging
#
SQLITE_PATH=/opt/MODEL05042026/data/signals.sqlite3
LOG_LEVEL=INFO
ANALYTICS_ENABLED=true
ANALYTICS_LOG_POSITION_MARKS=true
ANALYTICS_LOG_PORTFOLIO_SNAPSHOTS=true
ANALYTICS_PORTFOLIO_SNAPSHOT_ON_EMERGING=false
ANALYTICS_POST_EXIT_BARS=24

#
# Telegram
#
# Rotate your Telegram token before using this file.
TELEGRAM_BOT_TOKEN=REPLACE_WITH_ROTATED_TOKEN
TELEGRAM_CHAT_ID=REPLACE_WITH_CHAT_ID

#
# Optional universe override
#
# Optional: override the manual universe.
# UNIVERSE=INJUSDT,STXUSDT,RENDERUSDT
